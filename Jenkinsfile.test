pipeline {

    agent any


    stages {

        stage('Install Test Dependencies') {

            steps {

                sh '''
                python3 -m pip install pytest
                '''

            }
        }


        stage('Execute Tests') {

            steps {

                sh '''
                pytest test_app.py
                '''

            }
        }

    }


    post {

        success {
            echo "Testing completed"
        }

    }
}
